{
  "name": "widgetly",
  "version": "0.1.0",
  "private": true,
  "description": "Widgetly - One Search. Endless Possibilities. An AI-powered utility platform with 500+ tools.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "render:remotion": "remotion render src/remotion/index.tsx Audience out/remotion.mp4 --codec h264 --frames-per-second 30 --quality 80",
    "lint": "eslint .",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "ship": "node scripts/ship.mjs",
    "ship:build": "node scripts/ship.mjs --build",
    "prepare": "husky",
    "prebuild": "node scripts/sync-swagger-assets.mjs",
    "sync:swagger": "node scripts/sync-swagger-assets.mjs",
    "i18n:translate": "node scripts/translate-messages.mjs",
    "i18n:translate:libre": "node scripts/translate-messages.mjs --provider=libretranslate",
    "i18n:translate:deepl": "node scripts/translate-messages.mjs --provider=deepl",
    "i18n:translate:google": "node scripts/translate-messages.mjs --provider=google",
    "i18n:translate:gemini": "node scripts/translate-messages.mjs --provider=gemini",
    "i18n:translate:gemini:vertex": "GEMINI_VERTEX_TOKEN=${GEMINI_VERTEX_TOKEN:-$(gcloud auth print-access-token 2>/dev/null)} GEMINI_PROJECT_ID=${GEMINI_PROJECT_ID} node scripts/translate-messages.mjs --provider=gemini",
    "i18n:translate:auto": "DEEPL_API_KEY=$DEEPL_API_KEY GOOGLE_TRANSLATE_API_KEY=$GOOGLE_TRANSLATE_API_KEY GEMINI_API_KEY=$GEMINI_API_KEY GEMINI_VERTEX_TOKEN=$GEMINI_VERTEX_TOKEN node scripts/translate-messages.mjs --provider=auto",
    "i18n:translate:mock": "node scripts/translate-messages.mjs --provider=mock --delay=0",
    "i18n:translate:dry": "node scripts/translate-messages.mjs --provider=libretranslate --dry-run --delay=0",
    "i18n:export": "node scripts/translate-file.mjs export --locales=es,fr --out=tmp/translate",
    "i18n:export:all": "node scripts/translate-file.mjs export --out=tmp/translate",
    "i18n:export:missing": "node scripts/translate-file.mjs export --locales=es,fr --out=tmp/translate --mode=missing",
    "i18n:import": "node scripts/translate-file.mjs import --dir=tmp/translate",
    "i18n:translate:mvp": "node scripts/translate-messages.mjs --locales=es,fr",
    "setup:secrets": "node scripts/setup-cloudflare-secrets.mjs",
    "setup:secrets:dry": "node scripts/setup-cloudflare-secrets.mjs --dry-run",
    "db:migrate:local": "wrangler d1 migrations apply widgetly --local",
    "db:migrate:remote": "wrangler d1 migrations apply widgetly --remote",
    "db:create": "wrangler d1 create widgetly",
    "db:info": "wrangler d1 info widgetly",
    "db:console:local": "wrangler d1 execute widgetly --local --command",
    "db:console:remote": "wrangler d1 execute widgetly --remote --command",
    "db:seed:local": "node scripts/seed-leaderboard.mjs",
    "db:seed:remote": "node scripts/seed-leaderboard.mjs --remote",
    "seed:admin:local": "node scripts/seed-admin.mjs",
    "seed:admin:remote": "D1_BINDING=remote node scripts/seed-admin.mjs"
  },
  "remotion": {
    "webpackOverride": "./remotion/webpack.override.js"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "swagger-ui-dist": "^5.32.6",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "remotion": "^4.0.475",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.100.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
