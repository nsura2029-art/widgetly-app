{
  "name": "widgetly",
  "version": "0.1.0",
  "private": true,
  "description": "Widgetly - One Search. Endless Possibilities. An AI-powered utility platform with 500+ tools.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "render:remotion": "remotion render src/remotion/index.tsx Audience out/remotion.mp4 --codec h264 --frames-per-second 30 --quality 80",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css}\"",
    "prepare": "husky",
    "prebuild": "node scripts/sync-swagger-assets.mjs",
    "sync:swagger": "node scripts/sync-swagger-assets.mjs"
  },
  "remotion": {
    "webpackOverride": "./remotion/webpack.override.js"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "swagger-ui-dist": "^5.32.6",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "remotion": "^4.0.475",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.100.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
