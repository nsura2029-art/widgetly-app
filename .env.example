# Cloudflare deployment credentials
# Get from https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional: KV namespace for waitlist persistence
# Create with: wrangler kv:namespace create WAITLIST
WAITLIST_KV=

# Optional: Cloudflare Web Analytics token
NEXT_PUBLIC_ANALYTICS_TOKEN=

# --------------------------------------------------------------------------
# Supabase (persistence for /api/waitlist and /api/suggest)
# --------------------------------------------------------------------------
# When both are set, the API routes persist to Supabase (Postgres). When
# either is unset, the routes fall back to the webhook-only path.
#
# Local dev:    copy this file to .env.local and fill in.
# Cloudflare:   `wrangler secret put SUPABASE_URL`
#               `wrangler secret put SUPABASE_SERVICE_ROLE_KEY`
#
# The service role key bypasses RLS server-side. NEVER expose it to the
# browser. The anon key is not used by the current API; if you later
# need client-side reads, create a separate key with a narrow policy.
#
# DO NOT put real values in this file. .env.example is committed to git
# and lives in your public repo. Real values go in .env.local (dev) or
# `wrangler secret put` (prod). Placeholders below match the shape the
# server reads; copy them as-is into .env.local and fill in.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------------------
# Webhook fallbacks (used only when Supabase is NOT configured)
# --------------------------------------------------------------------------
WAITLIST_WEBHOOK_URL=
SUGGEST_WEBHOOK_URL=


# --------------------------------------------------------------------------
# Clerk (user authentication)
# --------------------------------------------------------------------------
# Get keys at https://dashboard.clerk.com → API Keys
# - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY starts with pk_test_ (or pk_live_ in prod)
# - CLERK_SECRET_KEY starts with sk_test_ (or sk_live_ in prod)
#
# Local dev:    copy this file to .env.local and fill in.
# Cloudflare:   `wrangler secret put NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY --env stage`
#               `wrangler secret put CLERK_SECRET_KEY --env stage`
# CI:           run the "Set stage Clerk secrets" workflow:
#               https://github.com/nsura2029-art/widgetly-app/actions/workflows/set-stage-clerk-secrets.yml
#
# Both keys must be set together. The middleware (src/middleware.ts)
# skips clerkMiddleware when the publishable key is missing; auth
# gating then falls back to a stub. When the keys ARE set, real
# sign-in / sign-up / session works.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
