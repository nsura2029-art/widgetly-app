#!/usr/bin/env sh
# .husky/pre-push
#
# Pre-push gate. Delegates to `scripts/ship.mjs` so the hook body and the
# manual `pnpm ship` command can never drift. See root AGENTS.md § "Ship
# Cycle / Definition of Done" for the full gate.
#
# husky v9+ contract (DO NOT REVERT to the v8 source-line below):
#   #!/usr/bin/env sh
#   # no `. "$(dirname -- "$0")/_/husky.sh"` — that line was removed in v9
#   node scripts/ship.mjs --skip-build
#
# The `_/husky.sh` shim is no longer generated by `husky init` in v9+. Source-
# ing it now emits a deprecation warning AND breaks on fresh clones where the
# `_/` directory doesn't exist (the file is in `.gitignore`).
#
# This hook is committed to the repo (tracked). Keep it executable:
#   chmod +x .husky/pre-push
# Do not `cd` inside the hook — CWD is already the repo root.

set -e

node scripts/ship.mjs --skip-build